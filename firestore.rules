rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
            && data.email is string && data.email.size() <= 256
            && data.createdAt == request.time;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && isValidId(userId);
      allow update: if isOwner(userId) 
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']);
    }

    // --- Readings Rules ---
    match /users/{userId}/readings/{readingId} {
      function isValidReading(data) {
        return data.userId == userId 
            && data.role in ['user', 'spirit']
            && data.content is string && data.content.size() <= 5000
            && data.timestamp == request.time;
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && isValidReading(request.resource.data) 
                    && isValidId(readingId);
      // No updates or deletes for readings to maintain history integrity
    }
  }
}
