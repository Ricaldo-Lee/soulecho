{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Reading": {
      "title": "Reading",
      "description": "A numerology reading or message exchanged with the spiritual entity.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "spirit"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Primary user documents."
    },
    "/users/{userId}/readings/{readingId}": {
      "schema": "Reading",
      "description": "Messages and readings associated with a specific user."
    }
  }
}
