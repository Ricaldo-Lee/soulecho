# DeepSeek：本项目仅使用 DeepSeek
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
# 可选：deepseek-chat / deepseek-reasoner
DEEPSEEK_MODEL="deepseek-chat"
# 可选：默认 https://api.deepseek.com
# DEEPSEEK_API_BASE="https://api.deepseek.com"

# AI_PROVIDER: 固定 deepseek
AI_PROVIDER="deepseek"

# APP_URL: 前端地址，用于 CORS（可逗号分隔多个，如 http://localhost:3000,http://127.0.0.1:3000）
APP_URL="http://localhost:3000"

# Supabase（服务端）
SUPABASE_URL="MY_SUPABASE_URL"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# Supabase（前端 Vite）
VITE_SUPABASE_URL="MY_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# 后端 API 基地址（前端请求）。本地开发可不填：将使用相对路径 /api，由 Vite 代理到 3001。
# 打包部署时若 API 与前端不同域，须设为完整 URL（如 https://api.example.com）。
# VITE_API_URL="http://localhost:3001"

# 阿里云号码认证 PNVS（SendSmsVerifyCode，服务端 /api/auth/phone/send-code 直接调用）
# AccessKey ID 通常以 LTAI 开头；AccessKey Secret 为另一串长密钥，勿把二者填反
ALIYUN_ACCESS_KEY_ID="MY_ALIYUN_ACCESS_KEY_ID"
ALIYUN_ACCESS_KEY_SECRET="MY_ALIYUN_ACCESS_KEY_SECRET"
# 必须填写 PNVS 控制台可用签名（通常为赠送签名，不可写“没有”）
ALIYUN_SMS_SIGN_NAME="速通互联验证码"
# 必须填写 PNVS 控制台可用模板 CODE（需包含变量 ${code}）
ALIYUN_SMS_TEMPLATE_CODE="100001"

# 自定义手机验证码：用于哈希存储短信 OTP（随机长串，勿泄露）
PHONE_OTP_PEPPER="use-openssl-rand-hex-32-or-similar"

# 手机登录不依赖 Supabase Phone Provider / Send SMS Hook；验证通过后服务端用 Admin generateLink(magiclink)。
# 若 generateLink 失败，可在 Dashboard 打开 Email 提供方（无需配置 SMTP，仅用于 magiclink 流程）。

PORT=3001
